{
  "name": "correcao-financeira",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=packages/web\"",
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/api && npm run build --workspace=packages/web",
    "test": "npm run test --workspace=packages/core",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
